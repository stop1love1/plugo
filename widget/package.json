{
  "name": "plugo-widget",
  "version": "1.0.0",
  "description": "Plugo - Embeddable AI Chat Widget",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@preact/preset-vite": "^2.9.0",
    "eslint": "^9.9.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "terser": "^5.46.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
