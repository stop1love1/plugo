# ============================================
# Plugo — Secrets Only
# ============================================
# Project configuration is in config.json
# This file contains only API keys and secrets.
# Copy to .env and fill in your values.

# --- Admin Login (REQUIRED — must not be defaults) ---
# The backend refuses to start if these are empty or set to the legacy default "pluginme".
USERNAME=
PASSWORD=

# --- Security ---
# IMPORTANT: Generate a strong random key for production
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string

# --- MongoDB (only used when config.json → database.provider="mongodb") ---
# Defaults in docker-compose are development-only — change before any deployment.
MONGO_USER=plugo
MONGO_PASSWORD=change-me-before-production

# --- API Keys (fill in the ones you use) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
