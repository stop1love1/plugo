# ============================================
# Plugo - Embeddable AI Chat Widget
# ============================================

# --- LLM Configuration ---
# Supported: claude | openai | gemini | ollama
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514

# --- API Keys (fill in the ones you use) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# --- Ollama (local models) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Embedding ---
# Supported: openai | ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Database ---
# Supported: sqlite | mongodb
DATABASE_PROVIDER=sqlite
DATABASE_URL=sqlite:///./data/plugo.db

# --- MongoDB (when DATABASE_PROVIDER=mongodb) ---
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=plugo

# --- Vector Store ---
CHROMA_PATH=./data/chroma

# --- Security ---
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_ENABLED=true

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_CRAWL=5/minute

# --- Server ---
BACKEND_PORT=8000
DASHBOARD_PORT=3000
WIDGET_CDN_URL=http://localhost:8000/static/widget.js
