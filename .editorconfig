# EditorConfig — https://editorconfig.org
# Ensures consistent coding styles across editors and IDEs.

root = true

# ──────────────────────────────────────
# Default: all files
# ──────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# ──────────────────────────────────────
# Python (Backend)
# ──────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 120

# ──────────────────────────────────────
# JavaScript / TypeScript (Widget, Dashboard)
# ──────────────────────────────────────
[*.{js,jsx,ts,tsx}]
indent_size = 2

# ──────────────────────────────────────
# Web (HTML, CSS)
# ──────────────────────────────────────
[*.{html,css,scss}]
indent_size = 2

# ──────────────────────────────────────
# Configuration files
# ──────────────────────────────────────
[*.{json,yml,yaml,toml}]
indent_size = 2

[docker-compose.yml]
indent_size = 2

# ──────────────────────────────────────
# Markdown
# ──────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ──────────────────────────────────────
# Makefile (requires tabs)
# ──────────────────────────────────────
[Makefile]
indent_style = tab

# ──────────────────────────────────────
# Shell scripts
# ──────────────────────────────────────
[*.sh]
indent_size = 2
end_of_line = lf

# ──────────────────────────────────────
# Git / Docker
# ──────────────────────────────────────
[{.gitignore,.dockerignore,Dockerfile}]
indent_size = 2
